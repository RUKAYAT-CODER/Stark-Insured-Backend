# Error Tracking & Sentry Configuration

# Sentry DSN (Data Source Name)
# Get this from your Sentry project settings: https://sentry.io/
# Format: https://<key>@<organization>.ingest.sentry.io/<project>
SENTRY_DSN=https://examplePublicKey@sentry.io/example_projectId

# Environment name for error tracking
# Options: development, staging, production
NODE_ENV=development

# Application version (sent with error reports)
APP_VERSION=1.0.0

# Sentry Traces Sample Rate
# Percentage of transactions to send to Sentry (0.0 to 1.0)
# 0.1 = 10% of transactions
# Set to 1.0 in production to get all transactions, or lower for high-traffic apps
SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry Profiles Sample Rate
# Percentage of transactions to profile (0.0 to 1.0)
# Only works with Profiling integration
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Filter 404 errors in Sentry
# If true, 404 errors won't be sent to Sentry (reduces noise)
SENTRY_FILTER_404S=false

# Sentry Server URL (optional, for self-hosted Sentry)
# If not set, uses Sentry.io
# Format: https://your-sentry-server.com
# SENTRY_SERVER_URL=

# Maximum breadcrumbs to keep (default: 50)
# Breadcrumbs are events leading up to an error
SENTRY_MAX_BREADCRUMBS=50

# Maximum value length for Sentry events
# Truncates very large values to avoid payload size issues
SENTRY_MAX_VALUE_LENGTH=1024
